# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=adaptai
# Generate a strong password: openssl rand -base64 32
DB_PASS=
DB_NAME=adaptai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Generate a strong password: openssl rand -base64 32
REDIS_PASS=

# JWT — REQUIRED. Generate with: openssl rand -base64 48
# Must be at least 32 characters in production. The backend will refuse
# to start if this is unset.
JWT_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Backend
BACKEND_PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins for the API and gateway.
# REQUIRED in production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Production-only URLs (must use https://)
FRONTEND_URL=
API_PUBLIC_URL=

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001
